# --- OpenRouter ---
# Get a key at https://openrouter.ai/keys
# IMPORTANT: also set a hard spend cap on your OpenRouter account (Settings → Limits)
# so a bug or abuse can never drain your balance.
OPENROUTER_API_KEY=

# Model used for the recruiter/tech-recruiter judgment + synthesis passes.
# One-line swap to upgrade quality: e.g. anthropic/claude-opus-4.6
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# --- Access gate ---
# The single shared password that unlocks the app.
APP_PASSWORD=change-me
# A long random string used to sign the auth cookie (e.g. `openssl rand -hex 32`).
AUTH_SECRET=change-me-to-a-long-random-string

# --- Optional ---
# Vision fallback. When "true" (default), the original PDF is sent to the vision model
# ONLY when text extraction is poor (e.g. a scanned or multi-column "designer" CV) —
# clean text PDFs use text extraction to keep token costs down. Set "false" to disable
# the fallback entirely (pure text).
ENABLE_VISION=true
